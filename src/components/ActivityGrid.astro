---
import type { GitHubContribution } from "../lib/github";

interface Props {
  contributions: GitHubContribution[];
  username: string;
}

const { contributions, username } = Astro.props;
const days = contributions
  .toSorted((a, b) => a.date.localeCompare(b.date))
  .slice(-364);
const total = days.reduce((sum, day) => sum + day.count, 0);
const monthLabels = days.reduce<Array<{ label: string; column: number }>>((labels, day, index) => {
  const date = new Date(`${day.date}T00:00:00`);
  const label = date.toLocaleDateString("en", { month: "short" });
  if (date.getDate() <= 7 && labels.at(-1)?.label !== label) labels.push({ label, column: Math.floor(index / 7) + 1 });
  return labels;
}, []);
---

<div class="activity-card">
  <div class="activity-months" aria-hidden="true">
    {monthLabels.map((month) => <span style={`grid-column:${month.column}`}>{month.label}</span>)}
  </div>
  <div class="activity-grid" role="img" aria-label={`${total} GitHub contributions in the last year`}>
    {days.map((day) => <span class={`activity-day level-${day.level}`} title={`${day.date}: ${day.count} contribution${day.count === 1 ? "" : "s"}`}></span>)}
  </div>
  <div class="activity-summary">
    <span><strong>{total}</strong> contributions in the last year</span>
    <span class="activity-legend"><span>Less</span><i class="level-0"></i><i class="level-1"></i><i class="level-2"></i><i class="level-3"></i><i class="level-4"></i><span>More</span></span>
  </div>
  <a class="activity-link" href={`https://github.com/${username}`} target="_blank" rel="noreferrer">View complete activity on GitHub ↗</a>
</div>
