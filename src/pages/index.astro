---
const features = [
  {
    icon: "bolt",
    label: "Build intelligence",
    title: "Fast by default",
    description: "Parallel jobs, intelligent caching, and elastic runners turn every push into a production-ready build in minutes.",
    meta: "48% faster builds",
  },
  {
    icon: "shield",
    label: "Supply-chain security",
    title: "Secure at every step",
    description: "Scan dependencies, protect secrets, and enforce policy before code gets anywhere near production.",
    meta: "SOC 2 ready",
  },
  {
    icon: "pulse",
    label: "Live observability",
    title: "Know what is happening",
    description: "Follow every job in real time with searchable logs, meaningful alerts, and a complete deployment history.",
    meta: "Zero blind spots",
  },
];

const steps = [
  { number: "01", title: "Connect", copy: "Link your GitHub repository in a few clicks." },
  { number: "02", title: "Configure", copy: "Start from a smart workflow that fits your stack." },
  { number: "03", title: "Ship", copy: "Merge with confidence and deploy automatically." },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Forge is the CI/CD platform that helps modern teams build, test, and ship with confidence." />
    <meta name="theme-color" content="#07110e" />
    <title>Forge — Ship better software, faster</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="site-shell">
      <header class="nav-wrap">
        <nav class="nav container" aria-label="Main navigation">
          <a class="brand" href="#top" aria-label="Forge home">
            <span class="brand-mark" aria-hidden="true"><span></span></span>
            <span>FORGE</span>
          </a>
          <div class="nav-links">
            <a href="#platform">Platform</a>
            <a href="#workflow">How it works</a>
            <a href="#security">Security</a>
          </div>
          <a class="nav-cta" href="#start">Start shipping <span aria-hidden="true">↗</span></a>
        </nav>
      </header>

      <main id="top">
        <section class="hero container">
          <div class="hero-copy">
            <div class="eyebrow"><span></span> CI/CD without the drag</div>
            <h1>From commit<br />to <em>confidence.</em></h1>
            <p class="hero-lede">Build, test, and deploy on one beautifully simple platform. Forge gives engineering teams the speed to move and the control to scale.</p>
            <div class="hero-actions">
              <a class="button button-primary" href="#start">Start building free <span aria-hidden="true">→</span></a>
              <a class="button button-ghost" href="#workflow"><span class="play" aria-hidden="true">▶</span> See how it works</a>
            </div>
            <div class="proof">
              <div class="avatars" aria-hidden="true">
                <span>AM</span><span>KL</span><span>JR</span><span>+2k</span>
              </div>
              <p><strong>Trusted by 2,000+ teams</strong><br />shipping every day</p>
            </div>
          </div>

          <div class="pipeline-card" aria-label="Live deployment pipeline preview">
            <div class="card-glow"></div>
            <div class="pipeline-topbar">
              <div class="window-dots" aria-hidden="true"><span></span><span></span><span></span></div>
              <span class="repo"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 19c-4.5 1.4-4.5-2.5-6-3m12 6v-3.9c0-1.1.1-1.5-.5-2.1 2.8-.3 5.7-1.4 5.7-6.2 0-1.4-.5-2.5-1.3-3.4.1-.3.6-1.6-.1-3.3 0 0-1.1-.3-3.6 1.3a12.4 12.4 0 0 0-6.5 0C6.2 2.7 5.1 3.1 5.1 3.1c-.7 1.7-.2 3-.1 3.3a5 5 0 0 0-1.3 3.4c0 4.8 2.9 5.9 5.7 6.2-.5.5-.6 1-.6 2.1V22"/></svg> acme/atlas</span>
              <span class="live"><i></i> Live</span>
            </div>
            <div class="pipeline-body">
              <div class="deploy-heading">
                <div><span class="muted-label">DEPLOYMENT</span><h2>Production release</h2></div>
                <span class="success-pill">✓ Successful</span>
              </div>
              <div class="commit"><span class="commit-avatar">L</span><span><b>feat: ship command palette</b><small>lucy@acme · a83fcb2</small></span><span class="time">2m ago</span></div>
              <div class="pipeline-flow">
                <div class="flow-line"></div>
                <div class="job done"><span class="job-icon">✓</span><span><b>Build</b><small>38s</small></span></div>
                <div class="job done"><span class="job-icon">✓</span><span><b>Test</b><small>1m 12s</small></span></div>
                <div class="job active"><span class="job-icon rocket">↗</span><span><b>Deploy</b><small>14s</small></span></div>
              </div>
              <div class="log-window">
                <div class="log-title"><span>deploy-production</span><span>•••</span></div>
                <code><i>12:04:31</i> Preparing deployment...<br /><i>12:04:34</i> Uploading artifacts <b>100%</b><br /><i>12:04:41</i> <strong>✓ Deployment is live</strong><br /><span class="cursor-line">$ forge status <mark>production</mark><span class="cursor"></span></span></code>
              </div>
            </div>
            <div class="floating-status"><span class="status-icon">↗</span><span><b>Deployed successfully</b><small>Production · just now</small></span></div>
          </div>
        </section>

        <section class="metrics" aria-label="Platform statistics">
          <div class="container metric-grid">
            <div><strong>99.99<span>%</span></strong><p>Platform uptime</p></div>
            <div><strong>1.8<span>m</span></strong><p>Deployments this month</p></div>
            <div><strong>42<span>s</span></strong><p>Median build time</p></div>
            <div><strong>24<span>/7</span></strong><p>Expert support</p></div>
          </div>
        </section>

        <section class="section container" id="platform">
          <div class="section-intro">
            <div><div class="eyebrow"><span></span> Built for momentum</div><h2>Everything between<br /><em>idea and impact.</em></h2></div>
            <p>One platform for the entire delivery lifecycle. Powerful enough for platform teams, simple enough for everyone.</p>
          </div>
          <div class="feature-grid">
            {features.map((feature) => (
              <article class="feature-card">
                <div class:list={["feature-icon", feature.icon]} aria-hidden="true">
                  {feature.icon === "bolt" && <svg viewBox="0 0 24 24"><path d="M13 2 4.5 14h7L11 22l8.5-12h-7L13 2Z"/></svg>}
                  {feature.icon === "shield" && <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>}
                  {feature.icon === "pulse" && <svg viewBox="0 0 24 24"><path d="M3 12h4l2-7 4 14 2-7h6"/></svg>}
                </div>
                <span class="card-label">{feature.label}</span>
                <h3>{feature.title}</h3>
                <p>{feature.description}</p>
                <div class="card-meta"><span>✓</span> {feature.meta}</div>
              </article>
            ))}
          </div>
        </section>

        <section class="workflow-section" id="workflow">
          <div class="container workflow-wrap">
            <div class="workflow-copy">
              <div class="eyebrow light"><span></span> Simple by design</div>
              <h2>Your first deployment<br />before your <em>coffee cools.</em></h2>
              <p>No week-long migrations or endless YAML. Connect a repository and let Forge do the heavy lifting.</p>
              <a class="text-link" href="#start">Explore the platform <span>→</span></a>
            </div>
            <div class="steps">
              {steps.map((step) => (
                <div class="step">
                  <span class="step-number">{step.number}</span>
                  <div><h3>{step.title}</h3><p>{step.copy}</p></div>
                  <span class="step-check">✓</span>
                </div>
              ))}
            </div>
          </div>
        </section>

        <section class="security container" id="security">
          <div class="security-card">
            <div class="security-art" aria-hidden="true">
              <div class="orbit orbit-one"></div><div class="orbit orbit-two"></div>
              <div class="lock"><svg viewBox="0 0 24 24"><rect x="5" y="10" width="14" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3M12 14v3"/></svg></div>
            </div>
            <div class="security-copy">
              <div class="eyebrow"><span></span> Enterprise-grade security</div>
              <h2>Move fast.<br /><em>Stay protected.</em></h2>
              <p>Security is built into every layer—from isolated build environments to signed artifacts and granular access controls.</p>
              <div class="security-list"><span>✓ SSO & SAML</span><span>✓ Audit logs</span><span>✓ Secret scanning</span><span>✓ RBAC</span></div>
            </div>
          </div>
        </section>

        <section class="cta container" id="start">
          <div class="cta-inner">
            <div class="cta-grid" aria-hidden="true"></div>
            <div class="eyebrow light"><span></span> Your next release starts here</div>
            <h2>Ready to ship<br /><em>something great?</em></h2>
            <p>Start free. Connect your repository. Deploy in minutes.</p>
            <div class="hero-actions centered"><a class="button button-light" href="https://github.com/">Get started with GitHub <span>→</span></a><a class="button button-dark" href="mailto:hello@example.com">Talk to an expert</a></div>
            <small>No credit card required · Free for personal projects</small>
          </div>
        </section>
      </main>

      <footer class="footer container">
        <a class="brand dark-brand" href="#top"><span class="brand-mark"><span></span></span><span>FORGE</span></a>
        <p>Build with focus. Ship with confidence.</p>
        <div><a href="#platform">Platform</a><a href="#security">Security</a><a href="mailto:hello@example.com">Contact</a></div>
        <span>© {new Date().getFullYear()} Forge, Inc.</span>
      </footer>
    </div>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  :global(html) { scroll-behavior: smooth; }
  :global(body) { margin: 0; color: #10231d; background: #f4f3ec; font-family: "Manrope", system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
  :global(a) { color: inherit; text-decoration: none; }
  :global(svg) { display: block; }
  .site-shell { overflow: hidden; }
  .container { width: min(1180px, calc(100% - 48px)); margin-inline: auto; }
  .nav-wrap { position: absolute; z-index: 20; top: 0; left: 0; width: 100%; border-bottom: 1px solid rgba(18, 50, 40, .1); }
  .nav { height: 82px; display: flex; align-items: center; justify-content: space-between; }
  .brand { display: inline-flex; gap: 10px; align-items: center; font-weight: 800; letter-spacing: .15em; font-size: 17px; }
  .brand-mark { width: 24px; height: 24px; display: grid; place-items: center; border-radius: 7px; background: #153f31; transform: rotate(45deg); }
  .brand-mark span { width: 8px; height: 8px; background: #b9f657; border-radius: 2px; }
  .nav-links { display: flex; gap: 34px; font-size: 14px; font-weight: 600; color: #4f605a; }
  .nav-links a { transition: color .2s; }
  .nav-links a:hover { color: #0b2a20; }
  .nav-cta { padding: 11px 16px; border: 1px solid rgba(18, 50, 40, .18); border-radius: 8px; font-size: 13px; font-weight: 700; transition: all .2s; }
  .nav-cta:hover { color: white; background: #153f31; border-color: #153f31; }
  .hero { position: relative; min-height: 790px; display: grid; grid-template-columns: 1fr .95fr; gap: 70px; align-items: center; padding-top: 126px; padding-bottom: 70px; }
  .hero::before { content: ""; position: absolute; z-index: -1; width: 600px; height: 600px; left: -360px; top: 120px; border-radius: 50%; background: rgba(185,246,87,.18); filter: blur(70px); }
  .eyebrow { display: flex; align-items: center; gap: 9px; color: #416456; font: 500 11px/1 "DM Mono", monospace; letter-spacing: .12em; text-transform: uppercase; }
  .eyebrow span { width: 19px; height: 2px; background: #76a92e; }
  h1, h2, h3, p { margin-top: 0; }
  h1 { margin: 25px 0 25px; color: #102b22; font-size: clamp(58px, 6.2vw, 88px); line-height: .98; letter-spacing: -.065em; font-weight: 700; }
  h1 em, h2 em { color: #6e9b2f; font-weight: 500; font-style: italic; }
  .hero-lede { max-width: 600px; color: #52625d; font-size: 17px; line-height: 1.75; }
  .hero-actions { display: flex; gap: 12px; margin-top: 34px; }
  .button { min-height: 50px; display: inline-flex; align-items: center; justify-content: center; gap: 22px; padding: 0 22px; border-radius: 8px; font-size: 13px; font-weight: 700; transition: transform .25s, box-shadow .25s, background .25s; }
  .button:hover { transform: translateY(-2px); }
  .button-primary { color: #fff; background: #123f30; box-shadow: 0 10px 30px rgba(16,58,44,.16); }
  .button-primary:hover { background: #0a2e23; box-shadow: 0 14px 34px rgba(16,58,44,.25); }
  .button-ghost { border: 1px solid #d4d7ce; background: rgba(255,255,255,.45); }
  .play { font-size: 10px; color: #65952a; }
  .proof { display: flex; align-items: center; gap: 14px; margin-top: 48px; }
  .proof p { margin: 0; color: #78847f; font-size: 11px; line-height: 1.5; }
  .proof strong { color: #2d4039; font-size: 12px; }
  .avatars { display: flex; }
  .avatars span { width: 30px; height: 30px; display: grid; place-items: center; margin-left: -6px; border: 2px solid #f4f3ec; border-radius: 50%; color: white; background: #72867f; font-size: 8px; font-weight: 700; }
  .avatars span:first-child { margin-left: 0; background: #a76c45; }.avatars span:nth-child(2) { background: #4e7589; }.avatars span:nth-child(3) { background: #715d82; }.avatars span:last-child { color: #29443a; background: #dce8d2; }
  .pipeline-card { position: relative; color: #dbe7e2; background: #0b1f19; border: 1px solid #29463c; border-radius: 15px; box-shadow: 0 40px 70px rgba(13,40,32,.25); transform: perspective(1200px) rotateY(-2deg) rotateX(1deg); animation: float 6s ease-in-out infinite; }
  .card-glow { position: absolute; inset: -1px; z-index: -1; border-radius: inherit; box-shadow: 0 0 70px rgba(129,199,65,.13); }
  .pipeline-topbar { height: 53px; padding: 0 17px; display: flex; align-items: center; border-bottom: 1px solid #203a31; font: 500 10px "DM Mono", monospace; }
  .window-dots { display: flex; gap: 5px; margin-right: 26px; }.window-dots span { width: 7px; height: 7px; border-radius: 50%; background: #385148; }.window-dots span:first-child { background: #e37b60; }.window-dots span:nth-child(2) { background: #d5ae4b; }.window-dots span:last-child { background: #73a94b; }
  .repo { display: flex; align-items: center; gap: 7px; color: #9eb1a9; }.repo svg { width: 14px; fill: none; stroke: currentColor; stroke-width: 1.5; }
  .live { margin-left: auto; color: #b8c7c1; }.live i { display: inline-block; width: 6px; height: 6px; margin-right: 6px; border-radius: 50%; background: #9de14b; box-shadow: 0 0 0 4px rgba(157,225,75,.1); }
  .pipeline-body { padding: 25px; }
  .deploy-heading { display: flex; justify-content: space-between; align-items: flex-end; }
  .muted-label { color: #657c73; font: 500 8px "DM Mono", monospace; letter-spacing: .12em; }
  .deploy-heading h2 { margin: 7px 0 0; font-size: 19px; letter-spacing: -.03em; }
  .success-pill { color: #a8e55c; background: rgba(134,199,64,.1); border: 1px solid rgba(134,199,64,.2); border-radius: 20px; padding: 6px 9px; font: 500 8px "DM Mono", monospace; }
  .commit { display: flex; gap: 9px; align-items: center; margin-top: 23px; padding: 12px; border: 1px solid #253d35; border-radius: 8px; background: #10271f; font-size: 9px; }
  .commit-avatar { width: 24px; height: 24px; display: grid; place-items: center; color: #143325; background: #b8eb74; border-radius: 50%; font-weight: 800; }
  .commit b, .commit small { display: block; }.commit small { margin-top: 3px; color: #71877e; font: 400 7px "DM Mono", monospace; }.commit .time { margin-left: auto; color: #60756d; }
  .pipeline-flow { position: relative; display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin: 27px 0; }
  .flow-line { position: absolute; top: 12px; left: 15%; right: 15%; height: 1px; background: #365349; }
  .job { position: relative; z-index: 1; display: flex; align-items: center; gap: 7px; justify-content: center; }
  .job-icon { width: 25px; height: 25px; display: grid; place-items: center; border-radius: 50%; color: #142b23; background: #9bdc4b; border: 4px solid #0b1f19; font-size: 9px; }
  .job b, .job small { display: block; font-size: 8px; }.job small { margin-top: 2px; color: #5e766d; font: 400 7px "DM Mono", monospace; }.job.active .job-icon { color: #a9e65a; background: #1c372d; box-shadow: 0 0 0 1px #62983b inset; }
  .log-window { overflow: hidden; border: 1px solid #263f36; border-radius: 8px; background: #071713; }
  .log-title { height: 31px; padding: 0 12px; display: flex; align-items: center; justify-content: space-between; color: #6c8279; background: #10271f; font: 500 7px "DM Mono", monospace; }
  .log-window code { display: block; padding: 13px; color: #82978f; font: 400 7px/2 "DM Mono", monospace; }.log-window code i { color: #3e5a50; font-style: normal; }.log-window code b { color: #b2d989; }.log-window code strong { color: #9ddd50; }.cursor-line { display: block; margin-top: 3px; color: #c5d4ce; }.cursor-line mark { color: #a8df63; background: none; }.cursor { display: inline-block; width: 5px; height: 10px; margin-left: 3px; vertical-align: middle; background: #92cc4b; animation: blink 1s step-end infinite; }
  .floating-status { position: absolute; right: -32px; bottom: -31px; display: flex; align-items: center; gap: 10px; width: 210px; padding: 13px; color: #203d32; background: rgba(250,251,246,.96); border: 1px solid white; border-radius: 10px; box-shadow: 0 18px 45px rgba(18,45,36,.2); backdrop-filter: blur(12px); }
  .status-icon { width: 30px; height: 30px; display: grid; place-items: center; color: #142f25; background: #baf063; border-radius: 8px; }.floating-status b,.floating-status small { display: block; font-size: 9px; }.floating-status small { margin-top: 3px; color: #7a8983; font: 400 7px "DM Mono", monospace; }
  .metrics { color: #fff; background: #12382d; }
  .metric-grid { display: grid; grid-template-columns: repeat(4, 1fr); padding-block: 30px; }
  .metric-grid div { padding-left: 45px; border-left: 1px solid rgba(255,255,255,.12); }.metric-grid div:first-child { padding-left: 0; border: 0; }
  .metric-grid strong { font-size: 29px; letter-spacing: -.05em; }.metric-grid strong span { color: #a9df5c; }.metric-grid p { margin: 4px 0 0; color: #849d94; font-size: 10px; }
  .section { padding-block: 125px; }
  .section-intro { display: grid; grid-template-columns: 1fr .7fr; align-items: end; gap: 80px; margin-bottom: 55px; }
  .section-intro h2, .workflow-copy h2, .security-copy h2, .cta h2 { margin: 19px 0 0; color: #132f25; font-size: clamp(40px, 4.5vw, 62px); line-height: 1.05; letter-spacing: -.055em; }
  .section-intro > p { margin: 0 0 5px; color: #6a7873; font-size: 15px; line-height: 1.8; }
  .feature-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 15px; }
  .feature-card { position: relative; padding: 30px; background: #faf9f4; border: 1px solid #ddded6; border-radius: 12px; transition: transform .3s, box-shadow .3s; }.feature-card:hover { transform: translateY(-6px); box-shadow: 0 22px 55px rgba(35,58,49,.09); }
  .feature-icon { width: 43px; height: 43px; display: grid; place-items: center; margin-bottom: 45px; border-radius: 10px; background: #eaf3de; }.feature-icon svg { width: 21px; fill: none; stroke: #5f8f2d; stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round; }.feature-icon.bolt svg { fill: #87b94a; stroke: #5f8f2d; }
  .card-label { color: #75837d; font: 500 8px "DM Mono", monospace; text-transform: uppercase; letter-spacing: .1em; }
  .feature-card h3 { margin: 10px 0 13px; font-size: 21px; letter-spacing: -.035em; }.feature-card p { min-height: 74px; color: #6a7772; font-size: 12px; line-height: 1.75; }
  .card-meta { margin-top: 24px; padding-top: 16px; border-top: 1px solid #e1e2dc; color: #44554f; font: 500 9px "DM Mono", monospace; }.card-meta span { margin-right: 6px; color: #71a637; }
  .workflow-section { color: white; background: #0c211a; }
  .workflow-wrap { display: grid; grid-template-columns: .9fr 1fr; gap: 130px; align-items: center; min-height: 610px; padding-block: 80px; }
  .eyebrow.light { color: #7d9e91; }.eyebrow.light span { background: #a8df5d; }
  .workflow-copy h2 { color: white; }.workflow-copy h2 em { color: #a2d758; }.workflow-copy > p { margin: 25px 0 26px; color: #899d95; font-size: 13px; line-height: 1.8; }
  .text-link { color: #b1e367; font-size: 12px; font-weight: 700; }.text-link span { margin-left: 8px; }
  .steps { position: relative; }.steps::before { content: ""; position: absolute; left: 22px; top: 45px; bottom: 45px; width: 1px; background: #345047; }
  .step { position: relative; display: grid; grid-template-columns: 46px 1fr 24px; gap: 20px; align-items: center; padding: 26px 0; border-bottom: 1px solid #263d35; }.step:last-child { border: 0; }
  .step-number { z-index: 1; width: 46px; height: 46px; display: grid; place-items: center; color: #acd96f; background: #17342a; border: 1px solid #345449; border-radius: 50%; font: 500 9px "DM Mono", monospace; }.step h3 { margin: 0 0 6px; font-size: 17px; }.step p { margin: 0; color: #778d84; font-size: 11px; }.step-check { color: #8ec545; }
  .security { padding-block: 110px; }
  .security-card { display: grid; grid-template-columns: .8fr 1fr; min-height: 430px; overflow: hidden; background: #e3ecd8; border-radius: 16px; }
  .security-art { position: relative; display: grid; place-items: center; overflow: hidden; background: #15382d; }
  .security-art::before { content: ""; position: absolute; inset: 0; opacity: .12; background-image: linear-gradient(#fff 1px,transparent 1px),linear-gradient(90deg,#fff 1px,transparent 1px); background-size: 38px 38px; mask-image: radial-gradient(circle,black,transparent 75%); }
  .orbit { position: absolute; border: 1px solid rgba(178,228,105,.23); border-radius: 50%; }.orbit-one { width: 270px; height: 270px; }.orbit-two { width: 175px; height: 175px; }.orbit::after { content: ""; position: absolute; width: 8px; height: 8px; border-radius: 50%; background: #b5e86b; top: 17%; right: 12%; box-shadow: 0 0 16px #b5e86b; }
