---
import ActivityGrid from "../components/ActivityGrid.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { fallbackEvents, fallbackProfile, fallbackRepos } from "../data/fallback";
import { getGitHubPortfolio } from "../lib/github";
import "../styles/global.css";

const username = "Tareq-Bilal";
let profile = fallbackProfile;
let repos = fallbackRepos;
let events = fallbackEvents;

try {
  const github = await getGitHubPortfolio(username);
  profile = github.profile;
  repos = github.repos;
  events = github.events;
} catch (error) {
  console.warn("Using local GitHub fallback data:", error);
}

const featuredOrder = ["Revora", "MermaidFlow-Server", "Bookit", "E-Wallet-Server-Side", "Mood", "Fursa---Client"];
const ownRepos = repos.filter((repo) => !repo.isFork && repo.name !== username && repo.name !== "Master.Dev-CI-CD-Service");
const featured = featuredOrder
  .map((name) => ownRepos.find((repo) => repo.name === name))
  .filter((repo): repo is NonNullable<typeof repo> => Boolean(repo));
const remaining = ownRepos.filter((repo) => !featured.some((item) => item.name === repo.name));
const projects = [...featured, ...remaining].slice(0, 8);

const skills = [
  ["C#", "#a179dc"], [".NET Core", "#7c3aed"], ["Clean Architecture", "#8b5cf6"], ["SQL Server", "#ef4444"],
  ["PostgreSQL", "#3b82f6"], ["TypeScript", "#3178c6"], ["React", "#61dafb"], ["Next.js", "#a1a1aa"],
  ["GraphQL", "#e535ab"], ["Entity Framework", "#8b5cf6"], ["REST APIs", "#22c55e"], ["Jest", "#c21325"],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Tareq Abu Sharkh — Full Stack Software Engineer from Jordan specializing in .NET, React, and modern backend systems." />
    <meta name="theme-color" content="#09090b" />
    <meta property="og:title" content="Tareq Abu Sharkh — Software Engineer" />
    <meta property="og:description" content="Full Stack Engineer building reliable backend systems and thoughtful web experiences." />
    <meta property="og:image" content={profile.avatarUrl} />
    <title>Tareq Abu Sharkh — Software Engineer</title>
    <script is:inline>
      if (localStorage.getItem("theme") === "light") document.documentElement.classList.add("light-mode");
    </script>
  </head>
  <body>
    <div class="page-shell">
      <nav class="site-nav" aria-label="Main navigation">
        <div class="availability"><span class="status-dot"></span>Available for opportunities</div>
        <div class="nav-actions">
          <a class="nav-link" href="#projects">Projects</a>
          <a class="nav-link" href="#contact">Contact</a>
          <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle color theme">
            <svg class="sun-icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
            <svg class="moon-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.8 15.4A9 9 0 0 1 8.6 3.2 9 9 0 1 0 20.8 15.4Z"/></svg>
          </button>
        </div>
      </nav>

      <main>
        <section aria-labelledby="profile-name">
          <div class="profile-card">
            <div class="avatar-wrap"><img src={profile.avatarUrl} width="92" height="92" alt={`${profile.name}'s GitHub avatar`} /></div>
            <div class="profile-copy">
              <h1 class="profile-name" id="profile-name">{profile.name}<span class="verified" title="GitHub profile">✓</span></h1>
              <p class="profile-role">Full Stack Engineer · .NET backend developer · React frontend developer</p>
              <p class="profile-location"><span>●</span> {profile.location} · {profile.company}</p>
            </div>
            <a class="profile-social" href={profile.profileUrl} target="_blank" rel="noreferrer" aria-label="View GitHub profile">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .8a11.5 11.5 0 0 0-3.6 22.4c.6.1.8-.2.8-.5v-2c-3.3.7-4-1.4-4-1.4-.6-1.4-1.4-1.8-1.4-1.8-1.1-.8.1-.8.1-.8 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.3 3.6 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.6.1-3.2 0 0 1-.3 3.2 1.2a11 11 0 0 1 5.8 0C17 4.5 18 4.8 18 4.8c.6 1.6.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.5A11.5 11.5 0 0 0 12 .8Z"/></svg>
            </a>
          </div>
          <div class="quick-stats" aria-label="GitHub profile statistics">
            <div><strong>{profile.repositories}</strong><span>PUBLIC REPOSITORIES</span></div>
            <div><strong>{profile.followers}</strong><span>GITHUB FOLLOWERS</span></div>
            <div><strong>{new Set(repos.map((repo) => repo.language).filter(Boolean)).size}</strong><span>CORE LANGUAGES</span></div>
          </div>
        </section>

        <section class="content-section" aria-labelledby="skills-heading">
          <SectionHeading title="Skills & technologies" kicker="What I work with" />
          <div class="tags" id="skills-heading">
            {skills.map(([skill, color]) => <span class="tag" style={`--tag:${color}`}><i></i>{skill}</span>)}
          </div>
        </section>

        <section class="content-section" aria-labelledby="activity-heading">
          <SectionHeading title="GitHub activity" kicker="Recent momentum" />
          <div id="activity-heading"><ActivityGrid events={events} username={username} /></div>
        </section>

        <section class="content-section" aria-labelledby="experience-heading">
          <SectionHeading title="Experience" kicker="Where I build" />
          <div class="timeline" id="experience-heading">
            <article class="timeline-item">
              <span class="timeline-icon">OP</span>
              <div><h3>Software Development Engineer</h3><p class="timeline-company">Optimum Partners Global · Jordan</p><p class="timeline-description">Building dependable software products across backend services, data layers, and modern frontend applications.</p></div>
              <span class="timeline-period">CURRENT</span>
            </article>
            <article class="timeline-item">
              <span class="timeline-icon">GH</span>
              <div><h3>Full Stack & Open Source Developer</h3><p class="timeline-company">Independent · GitHub</p><p class="timeline-description">Designing .NET systems with clean architecture and creating responsive TypeScript and React experiences in public.</p></div>
              <span class="timeline-period">ONGOING</span>
            </article>
          </div>
        </section>

        <section class="content-section" id="projects" aria-labelledby="projects-heading">
          <SectionHeading title="Selected projects" kicker="Things I have shipped" />
          <div class="projects-list" id="projects-heading">
            {projects.map((project, index) => <ProjectCard project={project} index={index} hidden={index >= 4} />)}
          </div>
          {projects.length > 4 && <div class="view-more-wrap"><button class="view-more" id="view-more" type="button" aria-expanded="false">View more projects <span>⌄</span></button></div>}
        </section>

        <section class="content-section" id="contact" aria-labelledby="contact-heading">
          <SectionHeading title="Let’s build something" kicker="Get in touch" />
          <p class="contact-copy" id="contact-heading">I enjoy turning complex product ideas into clear, maintainable software. If you’re building something ambitious—or just want to talk architecture—my inbox is open.</p>
          <div class="contact-actions">
            <a class="contact-button primary" href="mailto:tareqbilal44@gmail.com"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h16v14H4zM4 7l8 6 8-6"/></svg>Email me</a>
            <a class="contact-button" href="https://linkedin.com/in/tareq-abu-sharkh" target="_blank" rel="noreferrer">LinkedIn ↗</a>
            <a class="contact-button" href={profile.profileUrl} target="_blank" rel="noreferrer">GitHub ↗</a>
          </div>
        </section>

        <footer>
          <div class="terminal-footer">
            <div class="terminal"><span class="arrow">➜</span><span class="tilde">~</span><span>dotnet run --project next-big-thing</span><i class="cursor"></i></div>
          </div>
          <div class="copyright"><span>© {new Date().getFullYear()} Tareq Abu Sharkh</span><a href={profile.profileUrl} target="_blank" rel="noreferrer">Built with Astro · Data from GitHub</a></div>
        </footer>
      </main>
    </div>

    <script>
      const root = document.documentElement;
      const themeButton = document.querySelector<HTMLButtonElement>("#theme-toggle");
      themeButton?.addEventListener("click", () => {
        root.classList.toggle("light-mode");
        localStorage.setItem("theme", root.classList.contains("light-mode") ? "light" : "dark");
      });

      const viewMore = document.querySelector<HTMLButtonElement>("#view-more");
      const projectList = document.querySelector<HTMLElement>(".projects-list");
      viewMore?.addEventListener("click", () => {
        const expanded = viewMore.getAttribute("aria-expanded") === "true";
        viewMore.setAttribute("aria-expanded", String(!expanded));
        viewMore.firstChild!.textContent = expanded ? "View more projects " : "Show fewer projects ";
        projectList?.classList.toggle("expanded", !expanded);
      });
    </script>
  </body>
</html>
