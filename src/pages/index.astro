---
import ActivityGrid from "../components/ActivityGrid.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { fallbackProfile, fallbackRepos } from "../data/fallback";
import { getGitHubPortfolio, type GitHubContribution } from "../lib/github";
import "../styles/global.css";

const username = "Tareq-Bilal";
let profile = fallbackProfile;
let repos = fallbackRepos;
let contributions: GitHubContribution[] = [];

try {
  const github = await getGitHubPortfolio(username);
  profile = github.profile;
  repos = github.repos;
  contributions = github.contributions;
} catch (error) {
  console.warn("Using local GitHub fallback data:", error);
}

const projectOrder = ["Revora", "Mood", "MermaidFlow-Client", "Bookify"];
const thumbnails: Record<string, string> = {
  Revora: "/projects/revora.webp",
  Mood: "/projects/mood.webp",
  "MermaidFlow-Client": "/projects/mermaid-flow.webp",
  Bookify: "/projects/bookify.webp",
};
const projectDescriptions: Record<string, string> = {
  Revora: "Cloud-native vehicle auctions powered by independently deployable .NET microservices, real-time SignalR bidding, event-driven messaging, PostgreSQL, and MongoDB.",
  Mood: "An AI-powered journal with real-time auto-saving, Gemini mood analysis, private Clerk authentication, and a thoughtful Next.js interface backed by Neon PostgreSQL.",
  "MermaidFlow-Client": "A responsive visual documentation tool for creating flowcharts, sequence diagrams, and system models from simple text with live rendering and export workflows.",
  Bookify: "A concurrency-safe booking management service using .NET 10, Clean Architecture, CQRS, PostgreSQL exclusion constraints, and a focused React calendar experience.",
};
const projects = projectOrder
  .map((name) => repos.find((repo) => repo.name === name))
  .filter((repo): repo is NonNullable<typeof repo> => Boolean(repo))
  .map((repo) => ({ ...repo, description: projectDescriptions[repo.name] }));

const stack = [
  { name: "C#", icon: "csharp" },
  { name: ".NET Core", icon: "dotnet" },
  { name: "React", icon: "react" },
  { name: "Next.js", icon: "nextdotjs" },
  { name: "Node.js", icon: "nodedotjs" },
  { name: "Express", icon: "express" },
  { name: "TypeScript", icon: "typescript" },
  { name: "PostgreSQL", icon: "postgresql" },
  { name: "SQL Server", icon: "microsoftsqlserver" },
  { name: "MongoDB", icon: "mongodb" },
  { name: "GraphQL", icon: "graphql" },
  { name: "RabbitMQ", icon: "rabbitmq" },
  { name: "Docker", icon: "docker" },
  { name: "AWS", icon: "aws" },
  { name: "IdentityServer", icon: "identityserver", extension: "png" },
  { name: "GitHub Actions", icon: "githubactions" },
  { name: "Redis", icon: "redis" },
  { name: "Jest", icon: "jest" },
  { name: "Tailwind CSS", icon: "tailwindcss" },
  { name: "New Relic", icon: "newrelic" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Tareq Abu Sharkh — .NET Software Engineer from Jordan building production platforms, scalable backends, and modern web experiences." />
    <meta name="theme-color" content="#09090b" />
    <meta property="og:title" content="Tareq Abu Sharkh — .NET Software Engineer" />
    <meta property="og:description" content="Full Stack Engineer working across .NET, GraphQL, React, Next.js, and production observability." />
    <meta property="og:image" content={profile.avatarUrl} />
    <link rel="icon" type="image/png" href={profile.avatarUrl} />
    <title>Tareq Abu Sharkh — .NET Software Engineer</title>
    <script is:inline>
      if (localStorage.getItem("theme") === "light") document.documentElement.classList.add("light-mode");
    </script>
  </head>
  <body>
    <div class="page-shell">
      <nav class="site-nav" aria-label="Main navigation">
        <div class="availability"><span class="status-dot"></span>Available for opportunities</div>
        <div class="nav-actions">
          <a class="nav-link resume-link" href="/Tareq-Abu-Sharkh-Resume.pdf" target="_blank" rel="noreferrer">Resume <span>↗</span></a>
          <a class="nav-link" href="#contact">Contact</a>
          <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle color theme">
            <svg class="sun-icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
            <svg class="moon-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.8 15.4A9 9 0 0 1 8.6 3.2 9 9 0 1 0 20.8 15.4Z"/></svg>
          </button>
        </div>
      </nav>

      <main>
        <section aria-labelledby="profile-name">
          <div class="profile-card">
            <div class="avatar-wrap"><img src={profile.avatarUrl} width="92" height="92" alt={`${profile.name}'s portrait`} /></div>
            <div class="profile-copy">
              <h1 class="profile-name" id="profile-name">{profile.name}<span class="verified" title="GitHub profile">✓</span></h1>
              <a class="profile-email" href="mailto:tareqbilal44@gmail.com">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 5h18v14H3zM3 7l9 6 9-6"/></svg>
                tareqbilal44@gmail.com
              </a>
              <p class="profile-role">I build reliable software for large-scale production platforms. Experienced across .NET backends, GraphQL services, React interfaces, testing, and observability.</p>
              <p class="profile-location"><span>●</span> Amman, Jordan · Full-Stack Engineer at Optimum Partners Global</p>
            </div>
            <a class="profile-social" href={profile.profileUrl} target="_blank" rel="noreferrer" aria-label="View GitHub profile">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .8a11.5 11.5 0 0 0-3.6 22.4c.6.1.8-.2.8-.5v-2c-3.3.7-4-1.4-4-1.4-.6-1.4-1.4-1.8-1.4-1.8-1.1-.8.1-.8.1-.8 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.3 3.6 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.6.1-3.2 0 0 1-.3 3.2 1.2a11 11 0 0 1 5.8 0C17 4.5 18 4.8 18 4.8c.6 1.6.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.5A11.5 11.5 0 0 0 12 .8Z"/></svg>
            </a>
          </div>
        </section>

        <section class="content-section activity-section" aria-labelledby="activity-heading">
          <SectionHeading title="GitHub activity" />
          <div id="activity-heading"><ActivityGrid contributions={contributions} username={username} /></div>
        </section>

        <section class="content-section" id="projects" aria-labelledby="projects-heading">
          <SectionHeading title="Projects" />
          <div class="projects-list" id="projects-heading">
            {projects.map((project, index) => <ProjectCard project={project} index={index} thumbnail={thumbnails[project.name]} />)}
          </div>
        </section>

        <section class="content-section" aria-labelledby="experience-heading">
          <SectionHeading title="Experience" />
          <div class="timeline" id="experience-heading">
            <article class="timeline-item">
              <span class="timeline-icon">↗</span>
              <div>
                <div class="experience-title-row"><h3>Full-Stack Engineer</h3><span class="latest-badge">LATEST WORK</span></div>
                <p class="timeline-company">Optimum Partners Global · Contracted to Bloomberg Media</p>
                <p class="timeline-description">Contributing to an enterprise-scale media platform across backend, frontend, and observability domains. Designing REST and GraphQL integrations, maintaining Jest test suites, and tracing production systems with New Relic and Humio Cloud.</p>
                <div class="experience-tags"><span>.NET</span><span>GraphQL</span><span>Next.js</span><span>Jest</span><span>New Relic</span></div>
              </div>
              <span class="timeline-period">AUG 2025 — PRESENT</span>
            </article>
            <article class="timeline-item education-item">
              <span class="timeline-icon">U</span>
              <div><h3>Bachelor’s Degree in Computer Science</h3><p class="timeline-company">University of Jordan</p><p class="timeline-description">Foundation in object-oriented programming, algorithms, database systems, software architecture, and engineering principles.</p></div>
              <span class="timeline-period">2021 — 2025</span>
            </article>
          </div>
        </section>

        <section class="content-section" aria-labelledby="stack-heading">
          <SectionHeading title="Stack" />
          <div class="tags stack-tags" id="stack-heading">
            {stack.map((technology) => (
              <span class="tag"><img src={`/icons/${technology.icon}.${technology.extension ?? "svg"}`} width="15" height="15" alt="" loading="lazy" />{technology.name}</span>
            ))}
          </div>
        </section>

        <section class="content-section" id="contact" aria-labelledby="contact-heading">
          <SectionHeading title="Reach out to me" />
          <p class="contact-copy" id="contact-heading">I’m open to .NET engineering opportunities and conversations about backend architecture, production systems, or ambitious software ideas. If you have something in mind, let’s talk.</p>
          <div class="contact-actions">
            <a class="contact-button primary" href="mailto:tareqbilal44@gmail.com"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h16v14H4zM4 7l8 6 8-6"/></svg>Email me</a>
            <a class="contact-button" href="https://linkedin.com/in/tareq-abu-sharkh" target="_blank" rel="noreferrer">LinkedIn ↗</a>
            <a class="contact-button" href={profile.profileUrl} target="_blank" rel="noreferrer">GitHub ↗</a>
            <a class="contact-button" href="/Tareq-Abu-Sharkh-Resume.pdf" target="_blank" rel="noreferrer">View résumé ↗</a>
          </div>
        </section>

        <footer>
          <div class="terminal-footer">
            <div class="terminal"><span class="arrow">➜</span><span class="tilde">~</span><span>dotnet run --project next-big-thing</span><i class="cursor"></i></div>
          </div>
          <div class="copyright"><span>© {new Date().getFullYear()} Tareq Abu Sharkh</span><a href={profile.profileUrl} target="_blank" rel="noreferrer">Built with Astro · Data from GitHub</a></div>
        </footer>
      </main>
    </div>

    <script>
      const root = document.documentElement;
      const themeButton = document.querySelector<HTMLButtonElement>("#theme-toggle");
      themeButton?.addEventListener("click", () => {
        root.classList.toggle("light-mode");
        localStorage.setItem("theme", root.classList.contains("light-mode") ? "light" : "dark");
      });
    </script>
  </body>
</html>
